# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./careerforge.db
# PostgreSQL: postgresql://user:password@host:5432/careerforge

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-string
# Generate: openssl rand -hex 32

# ─── AI Provider ──────────────────────────────────────────────────────────────
# PRIMARY — Google Gemini (free, works on all cloud IPs)
# Get key: https://aistudio.google.com → "Get API key" (no card needed)
GEMINI_API_KEY=AIza...

# FALLBACK — only needed if Gemini is unavailable
# GROQ_API_KEY=gsk_...       # blocked on Render free tier IPs
# OPENAI_API_KEY=sk-...

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourcompany.com

# ─── Email / SMTP (for OTP verification) ──────────────────────────────────────
# Gmail: enable 2FA → generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=CareerForge <your-email@gmail.com>
