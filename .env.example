# ============================================================
# CareerForge — Environment Variables (root reference copy)
# Real per-app .env files live in apps/api/.env and apps/web/.env
# This file documents every variable used across the system.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://careerforge:careerforge@localhost:5432/careerforge

# --- Auth / JWT ---
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30

# --- App URLs ---
API_PORT=4000
API_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# --- OTP ---
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# --- OAuth: Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/oauth/google/callback

# --- OAuth: GitHub ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4000/api/auth/oauth/github/callback

# --- Email provider (abstraction selects via EMAIL_PROVIDER) ---
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="CareerForge <noreply@yourdomain.com>"

# --- AI provider (used starting Phase 6, included here for completeness) ---
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# --- PDF export (Puppeteer) ---
# Local dev: run `npx puppeteer browsers install chrome` and set the path it prints.
# Production (Render/Ubuntu): typically /usr/bin/chromium-browser
PUPPETEER_EXECUTABLE_PATH=

# --- Payments (used starting Phase 5, included here for completeness) ---
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_PREMIUM=

# --- Feature flags ---
FEATURE_INTERVIEW_PREP=false
FEATURE_LINKEDIN_OPTIMIZER=false
FEATURE_JOB_TRACKER=false
FEATURE_CAREER_COACH=false
