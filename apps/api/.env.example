# Copy to .env and fill in real values. See root .env.example for the full
# reference list with comments; this is the subset apps/api actually reads.
DATABASE_URL=postgresql://careerforge:careerforge@localhost:5432/careerforge
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me-too
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
API_PORT=4000
API_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/oauth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4000/api/auth/oauth/github/callback
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="CareerForge <noreply@yourdomain.com>"

# Chat/AI features use whichever provider AI_PROVIDER selects (see root
# .env.example for the full set: AI_PROVIDER, GROQ_API_KEY, OPENROUTER_API_KEY).
# ANTHROPIC_API_KEY is separate and required for:
#   - the admin panel's "Generate with AI" template button
#   - scripts/bulkGenerateTemplates.ts (always calls Anthropic directly,
#     regardless of AI_PROVIDER — see the script's header comment for why)
ANTHROPIC_API_KEY=

# Cloudinary — resume photo uploads. Get these from your Cloudinary
# dashboard (Settings > API Keys). All three are required together.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
