// CareerForge — Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum SubscriptionTier {
  FREE
  PROFESSIONAL
  PREMIUM
}

enum OAuthProviderName {
  GOOGLE
  GITHUB
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ---------------------------------------------------------------------------
// Auth domain
// ---------------------------------------------------------------------------

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  passwordHash     String?
  fullName         String?
  isEmailVerified  Boolean          @default(false)
  role             Role             @default(USER)
  subscriptionTier SubscriptionTier @default(FREE)
  pointsBalance    Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  oauthAccounts     OAuthAccount[]
  otpCodes          OtpCode[]
  refreshTokens     RefreshToken[]
  templatePurchases TemplatePurchase[]
  resumes           Resume[]

  @@map("users")
}

model OAuthAccount {
  id             String            @id @default(uuid())
  provider       OAuthProviderName
  providerUserId String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  createdAt      DateTime          @default(now())

  @@unique([provider, providerUserId])
  @@map("oauth_accounts")
}

model OtpCode {
  id         String     @id @default(uuid())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  codeHash   String
  purpose    OtpPurpose
  expiresAt  DateTime
  attempts   Int        @default(0)
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([userId, purpose])
  @@map("otp_codes")
}

model RefreshToken {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Template purchases
// The templateId is a registry key (e.g. "executive-pro"), not a FK.
// Templates live in packages/templates/src/registry.ts, not the DB.
// This table only records who has purchased which template.
// ---------------------------------------------------------------------------

model TemplatePurchase {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  templateId  String
  purchasedAt DateTime @default(now())

  @@unique([userId, templateId])
  @@map("template_purchases")
}

// ---------------------------------------------------------------------------
// Resume core
//
// sections and theme are stored as Json because the section/entry shape is
// schema-driven at the application layer (packages/schema), not the database
// layer. This is what makes unlimited custom sections possible without a DB
// migration every time a user invents a new section type.
//
// schemaVersion and migrationVersion implement the explicit-migration contract.
// See packages/schema/src/resumeMigrations.ts. Nothing in this app reads
// sections directly off a row without passing it through runMigrations() first.
// ---------------------------------------------------------------------------

model Resume {
  id               String          @id @default(uuid())
  owner            User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId          String
  title            String
  theme            Json
  sections         Json
  schemaVersion    Int             @default(1)
  migrationVersion Int             @default(1)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  versions ResumeVersion[]

  @@index([ownerId])
  @@map("resumes")
}

model ResumeVersion {
  id               String   @id @default(uuid())
  resume           Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId         String
  title            String
  theme            Json
  sections         Json
  schemaVersion    Int
  migrationVersion Int
  label            String?
  createdAt        DateTime @default(now())

  @@index([resumeId, createdAt])
  @@map("resume_versions")
}
