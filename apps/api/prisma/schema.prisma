// CareerForge — Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum SubscriptionTier {
  FREE
  PROFESSIONAL
  PREMIUM
}

enum OAuthProviderName {
  GOOGLE
  GITHUB
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ---------------------------------------------------------------------------
// Auth domain
// ---------------------------------------------------------------------------

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  passwordHash     String?
  fullName         String?
  isEmailVerified  Boolean          @default(false)
  role             Role             @default(USER)
  subscriptionTier SubscriptionTier @default(FREE)
  pointsBalance    Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @default(now()) @updatedAt

  oauthAccounts        OAuthAccount[]
  otpCodes             OtpCode[]
  refreshTokens        RefreshToken[]
  templatePurchases    TemplatePurchase[]
  resumes              Resume[]
  pointsTransactions   PointsTransaction[]
  subscription         Subscription?
  careerProfile        CareerProfile?
  conversationSessions ConversationSession[]
  jobApplications      JobApplication[]
  adminAuditLogs       AdminAuditLog[]      @relation("AdminAuditLogAdmin")

  @@map("users")
}

model OAuthAccount {
  id             String            @id @default(uuid())
  provider       OAuthProviderName
  providerUserId String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  createdAt      DateTime          @default(now())

  @@unique([provider, providerUserId])
  @@map("oauth_accounts")
}

model OtpCode {
  id         String     @id @default(uuid())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  codeHash   String
  purpose    OtpPurpose
  expiresAt  DateTime
  attempts   Int        @default(0)
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([userId, purpose])
  @@map("otp_codes")
}

model RefreshToken {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Template purchases
// The templateId is a registry key (e.g. "executive-pro"), not a FK.
// Templates live in packages/templates/src/registry.ts, not the DB.
// This table only records who has purchased which template.
// ---------------------------------------------------------------------------

model TemplatePurchase {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  templateId  String
  purchasedAt DateTime @default(now())

  @@unique([userId, templateId])
  @@map("template_purchases")
}

// ---------------------------------------------------------------------------
// Resume core
//
// sections and theme are stored as Json because the section/entry shape is
// schema-driven at the application layer (packages/schema), not the database
// layer. This is what makes unlimited custom sections possible without a DB
// migration every time a user invents a new section type.
//
// schemaVersion and migrationVersion implement the explicit-migration contract.
// See packages/schema/src/resumeMigrations.ts. Nothing in this app reads
// sections directly off a row without passing it through runMigrations() first.
// ---------------------------------------------------------------------------

model Resume {
  id               String          @id @default(uuid())
  owner            User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId          String
  title            String
  theme            Json
  sections         Json
  // Full { role, content } chat transcript for the AI builder conversation
  // that produced/is refining this resume. Previously this only ever lived
  // in AIChatBuilderPage's local React state — combined with a route param
  // name bug that meant navigating back to an existing resume's chat never
  // even knew which resume it was for, there was no way to resume a prior
  // conversation at all. Nullable/defaults to empty since resumes created
  // any other way (e.g. "start from scratch" in the editor) have no chat.
  chatMessages     Json            @default("[]")
  schemaVersion    Int             @default(1)
  migrationVersion Int             @default(1)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  versions       ResumeVersion[]
  shareableLink  ShareableLink?

  @@index([ownerId])
  @@map("resumes")
}

model ResumeVersion {
  id               String   @id @default(uuid())
  resume           Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId         String
  title            String
  theme            Json
  sections         Json
  schemaVersion    Int
  migrationVersion Int
  label            String?
  createdAt        DateTime @default(now())

  @@index([resumeId, createdAt])
  @@map("resume_versions")
}

// ---------------------------------------------------------------------------
// Points ledger
// Balance is always derived (SUM of amounts) — never stored as a column.
// This means the displayed balance can never drift from the transaction history.
// ---------------------------------------------------------------------------

enum PointsTransactionType {
  EARN
  SPEND
}

enum PointsEarnReason {
  PROFILE_COMPLETION
  RESUME_COMPLETION
  DAILY_USAGE
  REFERRAL
  ADMIN_GRANT
}

enum PointsSpendReason {
  TEMPLATE_PURCHASE
  EXPORT_PREMIUM
  FEATURE_UNLOCK
}

model PointsTransaction {
  id          String                   @id @default(uuid())
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  type        PointsTransactionType
  amount      Int
  earnReason  PointsEarnReason?
  spendReason PointsSpendReason?
  description String?
  createdAt   DateTime                 @default(now())

  @@index([userId, createdAt])
  @@map("points_transactions")
}

// ---------------------------------------------------------------------------
// Subscriptions
// One active subscription per user. The stripeSubscriptionId links to the
// real Stripe object so webhook events can be reconciled.
// ---------------------------------------------------------------------------

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

model Subscription {
  id                   String             @id @default(uuid())
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String             @unique
  tier                 SubscriptionTier
  status               SubscriptionStatus
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @default(now()) @updatedAt

  @@map("subscriptions")
}

// ---------------------------------------------------------------------------
// Shareable resume links
// ---------------------------------------------------------------------------

model ShareableLink {
  id         String   @id @default(uuid())
  resume     Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId   String   @unique
  slug       String   @unique
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("shareable_links")
}
// ---------------------------------------------------------------------------
// NEW ENUMS — Phase 6: Career Knowledge Base
// ---------------------------------------------------------------------------

enum ProfileFactCategory {
  IDENTITY
  EXPERIENCE
  EDUCATION
  SKILL
  PROJECT
  CERTIFICATION
  LANGUAGE
  AWARD
  PUBLICATION
  GOAL
  PREFERENCE
  WRITING_STYLE
  MISSING_INFO
}

enum FactSource {
  USER_CONFIRMED
  AI_EXTRACTED
  AI_INFERRED
  SYSTEM_GENERATED
}

enum ConversationMode {
  RESUME_BUILDING
  JOB_APPLICATION
  CAREER_EXPLORATION
  ATS_OPTIMIZATION
  COVER_LETTER
  INTERVIEW_PREP
}

enum ApplicationStatus {
  SAVED
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

// ---------------------------------------------------------------------------
// Career Knowledge Base
// ---------------------------------------------------------------------------

model CareerProfile {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facts    ProfileFact[]

  @@map("career_profiles")
}

model ProfileFact {
  id              String              @id @default(uuid())
  profile         CareerProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId       String
  category        ProfileFactCategory
  key             String
  value           Json
  confidenceScore Int                 @default(50)
  source          FactSource          @default(AI_INFERRED)
  lastVerifiedAt  DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([profileId, key])
  @@index([profileId, category])
  @@map("profile_facts")
}

// ---------------------------------------------------------------------------
// Conversation Memory
// ---------------------------------------------------------------------------

model ConversationSession {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  title     String?
  context   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  ConversationMessage[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("conversation_sessions")
}

model ConversationMessage {
  id        String              @id @default(uuid())
  session   ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  role      String
  content   String
  toolCalls Json?
  createdAt DateTime            @default(now())

  @@index([sessionId, createdAt])
  @@map("conversation_messages")
}

// ---------------------------------------------------------------------------
// Job Tracker (feature-flagged — schema ready, routes guarded by flag)
// ---------------------------------------------------------------------------

model JobApplication {
  id             String            @id @default(uuid())
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  company        String
  role           String
  jobDescription String?
  url            String?
  status         ApplicationStatus @default(SAVED)
  appliedAt      DateTime?
  notes          String?
  resumeId       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userId, status])
  @@map("job_applications")
}

// ---------------------------------------------------------------------------
// Admin: Template metadata layer
// ---------------------------------------------------------------------------

model TemplateListing {
  id           String   @id
  isActive     Boolean  @default(true)
  category     String   @default("free")
  pointsCost   Int      @default(0)
  thumbnailUrl String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("template_listings")
}

// ---------------------------------------------------------------------------
// Admin: Dynamic subscription plans
// ---------------------------------------------------------------------------

model SubscriptionPlan {
  id                   String   @id @default(uuid())
  tierKey              String   @unique
  name                 String
  priceMonthlyUsd      Decimal  @db.Decimal(10, 2)
  description          String?
  features             Json     @default("[]")
  pointsGrantedMonthly Int      @default(0)
  stripePriceId        String?
  isActive             Boolean  @default(true)
  displayOrder         Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("subscription_plans")
}

// ---------------------------------------------------------------------------
// Admin: Audit log (append-only)
// ---------------------------------------------------------------------------

model AdminAuditLog {
  id         String   @id @default(uuid())
  admin      User     @relation("AdminAuditLogAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  adminId    String
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@map("admin_audit_logs")
}

// ---------------------------------------------------------------------------
// Admin: Dynamic (DB-stored) resume templates
// ---------------------------------------------------------------------------

model DynamicTemplate {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  category     String   @default("free")
  templateHtml String
  thumbnailUrl String?
  pointsCost   Int      @default(0)
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  promptUsed   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, displayOrder])
  @@map("dynamic_templates")
}
